<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>SevenConcentradorBridge</RootNamespace>
    <!-- Fonte única de versão: alimenta o assembly (lido pelo UpdateService) e o
         instalador (build-installer.bat extrai e passa /DAppVersion para o ISCC). -->
    <Version>0.7.2</Version>
    <ApplicationIcon>seven-logo.ico</ApplicationIcon>
    <!-- NotifyIcon na bandeja (TrayIcon.cs). Exige TFM -windows. -->
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

  <!-- Publish-only settings: self-contained x86 single-file exe -->
  <!-- WinExe = sem janela de console no exe publicado (roda silencioso/oculto). Dev mantém console. -->
  <PropertyGroup Condition="'$(PublishDir)' != ''">
    <OutputType>WinExe</OutputType>
    <PlatformTarget>x86</PlatformTarget>
    <RuntimeIdentifier>win-x86</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="SevenConcentradorBridge\**\*.cs" />
    <Compile Remove="docs\**\*" />
    <EmbeddedResource Remove="docs\**\*" />
    <Content Remove="docs\**\*" />
    <None Remove="docs\**\*" />
  </ItemGroup>

  <ItemGroup>
    <None Update="companytec.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
    </None>
    <None Update="companytec_shim.dll" Condition="Exists('companytec_shim.dll')">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
    </None>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
    </None>
    <None Update="seven-logo.ico">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
    </None>
  </ItemGroup>

</Project>
